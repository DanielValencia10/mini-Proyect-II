{
  "name": "server",
  "version": "0.0.1",
  "description": "Backend Node.js nativo + TypeScript + Socket.IO + Firebase Admin",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon -e ts,json --exec \"node --env-file=.env -r ts-node/register src/index.ts\"",
    "dev:api": "nodemon -e ts,json --exec \"node --env-file=.env -r ts-node/register src/api.ts\"",
    "dev:realtime": "nodemon -e ts,json --exec \"node --env-file=.env -r ts-node/register src/realtime.ts\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:api": "node dist/api.js",
    "start:realtime": "node dist/realtime.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "socket.io": "^4.8.3",
    "swagger-ui-dist": "^5.32.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@types/swagger-ui-dist": "^3.30.6",
    "@types/webrtc": "^0.0.47",
    "eslint": "^9.39.4",
    "globals": "^16.0.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4"
  }
}
