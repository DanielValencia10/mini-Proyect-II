# Firebase Admin SDK — JSON completo de la service account (en una sola línea)
# Descárgalo desde: Firebase Console > Project Settings > Service accounts > Generate new private key
FIREBASE_ADMIN_SDK_JSON={"type":"service_account","project_id":"your_project_id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your_project.iam.gserviceaccount.com","client_id":"..."}

PORT=3000
CLIENT_ORIGIN=http://localhost:5173
