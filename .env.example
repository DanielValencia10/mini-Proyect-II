# ── Frontend — Vite (bake-in en build time) ──────────────────────────────────
# Copia estas variables también en client/.env para desarrollo local con Docker
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:000000000000000000
VITE_BACKEND_URL=http://localhost:3000
VITE_STUN_SERVER=stun:stun.l.google.com:19302

# ── Backend — Node.js (Firebase Admin SDK) ────────────────────────────────────
# FIREBASE_ADMIN_SDK_JSON: JSON completo de la service account (una sola línea)
FIREBASE_ADMIN_SDK_JSON={"type":"service_account","project_id":"your_project_id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@your_project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
PORT=3000
CLIENT_ORIGIN=http://localhost:5173
